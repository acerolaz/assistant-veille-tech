# Application
APP_ENV=development
LOG_LEVEL=INFO

# Azure AI Inference (LLM)
AZURE_AI_INFERENCE_ENDPOINT=
AZURE_AI_INFERENCE_API_KEY=
AZURE_AI_INFERENCE_MODEL=Kimi-K2.6

# ChromaDB — use http://chromadb:8000 when running inside Docker (default)
# Use http://localhost:8002 for host-side scripts (make ingest, make scrape)
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=articles
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# NewsAPI
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2/everything

# PostgreSQL — use postgres:5432 when running inside Docker (default)
# Use localhost:5432 for host-side alembic commands (make migrate)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=veille
DB_URL=postgresql://postgres:postgres@postgres:5432/veille

# WebSub (PubSubHubbub) — leave empty to disable subscription on startup
WEBSUB_SECRET=
WEBSUB_HUB_URL=https://pubsubhubbub.appspot.com/
# Leave empty to auto-default to http://localhost:{BACKEND_PORT}/webhook/websub
# Set to a public HTTPS URL in production so the hub can reach this server
WEBSUB_CALLBACK_URL=
RSS_FEED_URLS=["https://medium.com/feed/tag/csharp","https://medium.com/feed/tag/python"]

# Backend ↔ Frontend
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
